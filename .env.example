# API
APP_PORT=8000

# MongoDB — local dev, or Atlas: mongodb+srv://… (use with `docker compose up`; no local mongo container needed)
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=watchtower

# LocalStack SQS (dummy keys are fine for local/dev)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SQS_INGRESS_QUEUE_NAME=watchtower-ingress
SQS_DLQ_QUEUE_NAME=watchtower-ingress-dlq
# Phase 2: POST /v1/events → SQS; run `ais-worker` to persist to Mongo
QUEUE_INGRESS=false
SQS_VISIBILITY_TIMEOUT=60
SQS_WAIT_TIME_SECONDS=1
SQS_MAX_RECEIVE_BEFORE_DLQ=5

# Phase 4: skip new intervention plans within this window (seconds)
INTERVENTION_COOLDOWN_SECONDS=300

# NVIDIA NIM (OpenAI-compatible). When set, watchtower uses the LLM; otherwise rules only.
# NVIDIA_API_KEY=
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b
# NVIDIA_TEMPERATURE=1
# NVIDIA_TOP_P=0.95
# NVIDIA_MAX_TOKENS=16384
# NVIDIA_REASONING_BUDGET=16384
# NVIDIA_ENABLE_THINKING=true
